{
  "name": "game-terrarium-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on-top Electron viewer: city/moss/network visualizations, dungeon game, and network defense with Ollama-driven AI strategy",
  "main": "build-node/main.js",
  "scripts": {
    "build:wasm": "node scripts/build_wasm.js",
    "build": "npm run build:wasm && vite build && tsc -p tsconfig.node.json",
    "check:dom": "npm run build && node build-node/scripts/validate_dom_ids.js",
    "smoke:escort-td": "npm run build && node build-node/scripts/escort_td_smoke.js",
    "test:escort-td": "npm run build && node --test build-node/scripts/escort_td_rules.test.js",
    "test:apps": "npm run build && node --test build-node/scripts/apps_build.test.js",
    "test:projects": "npm run build && node --test build-node/scripts/*.test.js",
    "smoke:planet-fleet": "tsc -p tsconfig.node.json && node build-node/scripts/planet_strategy_fleet_smoke.js",
    "smoke:planet-watchability": "tsc -p tsconfig.node.json && node build-node/scripts/planet_strategy_watchability_smoke.js",
    "smoke:start": "npm run build && node build-node/scripts/electron_start_smoke.js",
    "smoke": "npm run typecheck && npm run check:dom && npm run test:apps",
    "prestart": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "electron": "^42.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "express": "^5.2.1",
    "three": "^0.184.0",
    "ws": "^8.21.0"
  }
}
