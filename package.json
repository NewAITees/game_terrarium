{
  "name": "game-terrarium-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on-top Electron viewer: city/moss/network visualizations, dungeon game, and network defense with Ollama-driven AI strategy",
  "main": "build-node/main.js",
  "scripts": {
    "build": "node_modules/.bin/tsc -p tsconfig.json && node_modules/.bin/tsc -p tsconfig.node.json",
    "prestart": "npm run build",
    "typecheck": "node_modules/.bin/tsc -p tsconfig.json --noEmit && node_modules/.bin/tsc -p tsconfig.node.json --noEmit",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.21.0"
  }
}
