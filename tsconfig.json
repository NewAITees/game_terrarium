{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2022"],
    "noEmitOnError": true,
    "skipLibCheck": true,
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": true
  },
  "include": [
    "apps/colony/**/*.ts",
    "apps/network-defense/**/*.ts",
    "apps/planet-strategy/**/*.ts",
    "shared/types/**/*.ts",
    "shared/types/**/*.d.ts"
  ]
}
