{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2022"],
    "outDir": "build",
    "rootDir": ".",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": true
  },
  "include": [
    "apps/city-traffic/**/*.ts",
    "apps/moss/**/*.ts",
    "apps/escort-td/**/*.ts",
    "apps/submarine-cables/**/*.ts",
    "apps/submarine-network-3d/**/*.ts",
    "apps/colony/**/*.ts",
    "apps/network-smallworld/**/*.ts",
    "apps/network-defense/**/*.ts",
    "apps/network-ecosystem/**/*.ts",
    "apps/planet-strategy/**/*.ts",
    "game/**/*.ts",
    "shared/*.ts",
    "shared/types/**/*.ts",
    "shared/types/**/*.d.ts"
  ]
}


