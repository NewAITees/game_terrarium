{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "outDir": "build-node",
    "rootDir": ".",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "types": ["node", "electron"]
  },
  "include": [
    "main.ts",
    "server.ts",
    "game/**/*.ts",
    "scripts/**/*.ts",
    "shared/planet_strategy_fleet.ts",
    "shared/page_registry.ts",
    "shared/network-core-topology.ts",
    "shared/planet_strategy_watchability.ts",
    "shared/types/**/*.ts",
    "shared/types/**/*.d.ts"
  ]
}
